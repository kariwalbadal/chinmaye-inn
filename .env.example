# Chinmaye Hotels — booking engine secrets
# Copy to .env, fill in, then run: node scripts/build-booking-config.mjs
# .env is gitignored; only the generated js/booking-config.js is deployed.

# Paste each property's booking-engine link from the STAAH dashboard.
# Optional placeholders {checkin} {checkout} {adults} are substituted
# with the guest's selections (dates as YYYY-MM-DD).
# Example: https://www.swiftbook.io/inst/#home?propertyId=XXXXX&checkIn={checkin}&checkOut={checkout}

STAAH_INN_ENABLED=false
STAAH_INN_URL=

STAAH_GRAND_ENABLED=false
STAAH_GRAND_URL=

STAAH_DEOGHAR_ENABLED=false
STAAH_DEOGHAR_URL=
